12>add the below script
import com.atlassian.jira.component.ComponentAccessor
import com.atlassian.jira.issue.MutableIssue
import com.atlassian.jira.event.type.EventDispatchOption
import com.atlassian.jira.issue.customfields.option.Option
def issue = issue as MutableIssue
def cfm = ComponentAccessor.getCustomFieldManager()
def cf = cfm.getCustomFieldObjectByName('Project approval')
def optionsManager = ComponentAccessor.getOptionsManager()
def config = cf.getRelevantConfig(issue)
Option yesOption = optionsManager.getOptions(config).find { it.value == 'Yes' }
issue.setCustomFieldValue(cf, yesOption)
ComponentAccessor.getIssueManager().updateIssue(
        ComponentAccessor.getJiraAuthenticationContext().getLoggedInUser(),
        issue,
        EventDispatchOption.DO_NOT_DISPATCH,
        false)
