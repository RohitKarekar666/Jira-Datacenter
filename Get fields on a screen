import com.atlassian.jira.component.ComponentAccessor
import com.atlassian.jira.config.IssueTypeManager
import org.apache.log4j.Level
import org.apache.log4j.Logger

def log = Logger.getLogger("www.google.com")
log.setLevel(Level.DEBUG)

ComponentAccessor.getFieldScreenManager().getFieldScreens().each { it ->

    log.debug("screen: " + it.name) //display the screen name
    log.debug("tabs: " + it.getTabs()*.name) //display the tabs under the screens

    it.getTab(0).getFieldScreenLayoutItems().each { fsli ->

        log.debug(fsli.fieldId) // display the list of fields present under the screen
    }
 }
