1>Go to script runner
2>select script editor
3>click on create script and given the name
4>add the below script and save
import com.onresolve.scriptrunner.parameters.annotation.UserPicker
import com.onresolve.scriptrunner.parameters.annotation.GroupPicker
import com.atlassian.jira.component.ComponentAccessor
import com.atlassian.jira.user.ApplicationUser
import com.atlassian.crowd.embedded.api.Group
// ---- Form parameters (these make the form render) ----
@UserPicker(
    label = 'Select user',
    description = 'Pick the user to add to the group' 
)
ApplicationUser userToAdd
@GroupPicker(
    label = 'Select group',
    description = 'Pick the target group'
)
Group groupNametoAdd
// ---- Script logic ----
if (!userToAdd) {
    log.error("User doesn't exits") 
    return
}
//if user is already in the group then below query will executed
if (ComponentAccessor.getGroupManager().getGroupsForUser(userToAdd.name).contains(groupNametoAdd)) {
    log.error("user: $userToAdd.username already in the group: $groupNametoAdd.name")
    return
}
//if the group is dosen't exits below query will executed
if(!groupNametoAdd){
    log.error("Group dosen't exits")
}
//if the user is exits and group also exits then user will get added to the group
else {
ComponentAccessor.groupManager.addUserToGroup(userToAdd, groupNametoAdd)
log.error("User: $userToAdd.username added to the group: $groupNametoAdd.name")
}
5>now come to console 
6>select the created script file
7>Run
