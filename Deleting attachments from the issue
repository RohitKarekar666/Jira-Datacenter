import com.atlassian.jira.component.ComponentAccessor
import com.atlassian.jira.issue.AttachmentManager
import com.atlassian.jira.issue.attachment.Attachment

final String ISSUE_KEY = "CAT-2"   // <-- change to your issue key

def issue = ComponentAccessor.issueManager.getIssueByCurrentKey(ISSUE_KEY)
assert issue : "Issue not found: $ISSUE_KEY"

def mgr  = ComponentAccessor.attachmentManager as AttachmentManager
def atts = mgr.getAttachments(issue) as List<Attachment>

int deleted = 0
atts.each { Attachment a ->
    mgr.deleteAttachment(a)  // PERMANENT: deletes from DB + attachment store
    deleted++
}

log.error("Deleted ${deleted} attachment(s) from ${ISSUE_KEY}")

