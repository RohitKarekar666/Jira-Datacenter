import com.atlassian.jira.component.ComponentAccessor
import com.atlassian.jira.issue.MutableIssue
import com.atlassian.jira.issue.IssueManager
import com.atlassian.jira.user.ApplicationUser
import com.atlassian.jira.issue.link.IssueLink
import org.apache.log4j.Logger
import org.apache.log4j.Level

def log = Logger.getLogger("www.google.com")
log.setLevel(Level.DEBUG)

log.debug("Script started")

IssueManager im = ComponentAccessor.getIssueManager();
MutableIssue issue = im.getIssueObject("CAT-4")

def changeHistoryManager = ComponentAccessor.getChangeHistoryManager()
changeHistoryManager.getAllChangeItems(issue).each { it->

    log.debug(it.created.toString() + ":" + it.field + ": " + it.froms + " -> " + it.tos)
 }

log.debug("only Priority")

changeHistoryManager.getChangeItemsForField(issue, "Priority").each { it ->

    log.debug(it.created.toString() + ":" + it.field + ": " + it.froms + " -> " + it.tos)
 }
log.debug("Script ended")
